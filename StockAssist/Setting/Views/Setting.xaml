<UserControl x:Class="StockAssist.Setting.Views.Setting"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:StockAssist.Setting.ViewModels"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             mc:Ignorable="d" 
             ui:ThemeManager.RequestedTheme="Dark"
             d:DesignHeight="450" 
             d:DesignWidth="800">

    <UserControl.Resources>
        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="10,5,5,5"/>
            <Setter Property="Padding" Value="15"/>

            <Setter Property="Background" Value="#1E222B"/>

            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GroupBox}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" 
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" 
                        Background="#252D37" 
                        CornerRadius="5,5,0,0" 
                        Padding="12,10,12,10"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="0,0,0,1">

                                    <ContentPresenter ContentSource="Header" 
                                      TextBlock.Foreground="#E2E8F0" 
                                      TextBlock.FontSize="18" 
                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                </Border>

                                <ContentPresenter Grid.Row="1" 
                                  Margin="{TemplateBinding Padding}" 
                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#2D3139" 
            BorderBrush="#D1D1D1" 
            CornerRadius="5" 
            Padding="10" 
            Margin="10"
            HorizontalAlignment="Stretch"  
            VerticalAlignment="Stretch">

        <GroupBox Header="{Binding LangService.Resources[SystemSetting]}">
            <GroupBox.HeaderTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" 
                               Foreground="White" />
                </DataTemplate>
            </GroupBox.HeaderTemplate>

            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0*"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding LangService.Resources[LanguageSelect]}" 
                           Foreground="White" 
                           FontSize="16"
                           Margin="5,5,4.8,4.2" 
                           Grid.ColumnSpan="2"/>

                <ComboBox Grid.Row="1"
                          ui:ControlHelper.PlaceholderText="{Binding LangService.Resources[Placeholder]}"
                          ItemsSource="{Binding Languages}"
                          SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName" 
                          HorizontalAlignment="Stretch"
                          Margin="5,4.8,4.8,0" 
                          FontSize="16"
                          Grid.ColumnSpan="2"/>

                <TextBlock Grid.Row="2"  
                           Text="{Binding CopyRights}" 
                           Foreground="White" 
                           FontSize="14"
                           Margin="10,0,0,9.8"
                           VerticalAlignment="Bottom"
                           HorizontalAlignment="Left" Grid.ColumnSpan="2"/>
            </Grid>
        </GroupBox>
    </Border>
</UserControl>