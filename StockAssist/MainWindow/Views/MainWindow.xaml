<Window x:Class="StockAssist.MainWindow.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:StockAssist.MainWindow.ViewModels"
        xmlns:vmCrawler="clr-namespace:StockAssist.StockCrawler.ViewModels"
        xmlns:vmSetting="clr-namespace:StockAssist.Setting.ViewModels"
        xmlns:setting="clr-namespace:StockAssist.Setting.Views"
        xmlns:crawler="clr-namespace:StockAssist.StockCrawler.Views"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        Title="Stock Assist" 
        Height="710" 
        Width="1250"
        WindowState="Maximized">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Closing">
            <i:InvokeCommandAction Command="{Binding WindowClosingCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Storyboard x:Key="ExpandWidth">
            <DoubleAnimation Storyboard.TargetProperty="Width" 
                             From="44" 
                             To="200" 
                             Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="CollapseWidth">
            <DoubleAnimation Storyboard.TargetProperty="Width" 
                             From="200" 
                             To="44" 
                             Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="FadeInText">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                             From="0" 
                             To="1" 
                             Duration="0:0:0.2" 
                             BeginTime="0:0:0.1" />
        </Storyboard>

        <Storyboard x:Key="FadeOutText">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                             To="0" 
                             Duration="0:0:0.1" />
        </Storyboard>

        <Style x:Key="SideMenuBorderStyle" TargetType="Border">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMenuOpen}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard Storyboard="{StaticResource ExpandWidth}"/>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard Storyboard="{StaticResource CollapseWidth}"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="ui:ControlHelper.CornerRadius" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2,4,2,0"/>
            <Style.Resources>
                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#25FFFFFF" />
                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#40FFFFFF" />
                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#DDDDDD" />
                <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
            </Style.Resources>
        </Style>

        <Style x:Key="NavigationButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2D323A" />
            <Setter Property="ui:ControlHelper.CornerRadius" Value="8" />
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="2,4,2,4"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
            <Style.Resources>
                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#3E444F" />
                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#1F2328" />
                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#CCCCCC" />
                <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
            </Style.Resources>
        </Style>

        <Style x:Key="MenuTextStyle" TargetType="TextBlock">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMenuOpen}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard Storyboard="{StaticResource FadeInText}"/>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard Storyboard="{StaticResource FadeOutText}"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#24292F">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="SideMenu" 
                Grid.Column="0" 
                Width="44" 
                Background="#24292F" 
                BorderBrush="Transparent" 
                Style="{StaticResource SideMenuBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="1" 
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" 
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Center" 
                          Width="36" 
                          Height="36">
                        <Button Command="{Binding ToggleMenuCommand}" 
                                Width="36" 
                                Height="36" 
                                Margin="0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ToggleButtonStyle}">
                                    <Setter Property="Width" Value="36"/>
                                    <Setter Property="Height" Value="36"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMenuOpen}" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="IsHitTestVisible" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Image x:Name="MainIco" 
                                       Source="pack://application:,,,/StockAssist.ico" 
                                       Width="36" 
                                       Height="36" 
                                       Margin="-1,0,-1,0" Stretch="Uniform"/>

                                <TextBlock x:Name="CollapsedArrow" 
                                           Text="⍈" 
                                           Foreground="White" 
                                           FontSize="26" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center" 
                                           Visibility="Collapsed"/>
                            </Grid>

                            <Button.Triggers>
                                <EventTrigger RoutedEvent="Mouse.MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="MainIco" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CollapsedArrow" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="Mouse.MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="MainIco" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CollapsedArrow" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Button.Triggers>
                        </Button>
                    </Grid>

                    <Button Grid.Column="1"
                            Command="{Binding ToggleMenuCommand}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,6,0"
                            Width="36" Height="36">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ToggleButtonStyle}">
                                <Setter Property="Width" Value="36"/>
                                <Setter Property="Height" Value="36"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMenuOpen}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <TextBlock x:Name="ExpandedDefaultIcon" 
                                       Text="◧" Foreground="White" 
                                       FontSize="22" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="ExpandedHoverIcon" 
                                       Text="⍇" Foreground="White" 
                                       FontSize="26" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" 
                                       Visibility="Collapsed"/>
                        </Grid>
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="Mouse.MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandedDefaultIcon" Storyboard.TargetProperty="Visibility">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandedHoverIcon" Storyboard.TargetProperty="Visibility">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Mouse.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandedDefaultIcon" Storyboard.TargetProperty="Visibility">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandedHoverIcon" Storyboard.TargetProperty="Visibility">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>

                <StackPanel Grid.Row="3">

                    <Button Command="{Binding NavigateCommand}" 
                            CommandParameter="StockCrawler">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavigationButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedViewIndex}" Value="0">
                                        <Setter Property="Background" Value="#2A5CA1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" 
                                       Text="📊" 
                                       FontSize="16" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="1" 
                                       Text="{Binding LangService.Resources[StockCrawler]}" 
                                       Style="{StaticResource MenuTextStyle}" 
                                       FontSize="20"/>
                        </Grid>
                    </Button>

                    <Button Command="{Binding NavigateCommand}" 
                            CommandParameter="Setting">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavigationButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedViewIndex}" Value="1">
                                        <Setter Property="Background" Value="#2A5CA1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" 
                                       Text="🛠️" 
                                       FontSize="16" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="1" 
                                       Text="{Binding LangService.Resources[Settings]}" 
                                       Style="{StaticResource MenuTextStyle}" 
                                       FontSize="20"/>
                        </Grid>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Column="1" 
                    SelectedIndex="{Binding SelectedViewIndex}" 
                    BorderThickness="0" 
                    Background="Transparent">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.ItemContainerStyle>

            <TabItem>
                <crawler:StockCrawler DataContext="{Binding StockCrawlerVM}" />
            </TabItem>

            <TabItem>
                <setting:Setting DataContext="{Binding SettingVM}" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>